# Copy to .env in the project root for Docker Compose (local or production server)
# On AWS EC2, place this at /opt/xebia-lms/.env (see deploy/scripts/server-setup.sh)

DOCKERHUB_USERNAME=your-dockerhub-username
# IMAGE_TAG is set automatically by CI on each deploy
IMAGE_TAG=latest

# PostgreSQL (bundled container — data in postgres_data volume)
POSTGRES_DB=lms
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-strong-password

# Redis (bundled container — cache in redis_data volume)
REDIS_HOST=redis
REDIS_PORT=6379

# Optional: Amazon RDS instead of bundled postgres (then: docker compose stop postgres)
# SPRING_DATASOURCE_URL=jdbc:postgresql://your-rds-endpoint.region.rds.amazonaws.com:5432/lms
# SPRING_DATASOURCE_USERNAME=postgres
# SPRING_DATASOURCE_PASSWORD=change-me

# Cloudinary (required for uploads in production)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Public HTTP port for the frontend/nginx container
FRONTEND_PORT=80
