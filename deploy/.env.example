DOCKERHUB_USERNAME=your-dockerhub-username
# IMAGE_TAG is set automatically by CI on each deploy — do not rely on this value
IMAGE_TAG=latest

# PostgreSQL (bundled container — data stored in postgres_data volume)
POSTGRES_DB=lms
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-strong-password

# Redis (bundled container — cache data stored in redis_data volume)
REDIS_HOST=redis
REDIS_PORT=6379

# Optional: use Amazon RDS instead of the postgres container above.
# When using RDS, stop the local postgres container after first deploy:
#   docker compose stop postgres
# SPRING_DATASOURCE_URL=jdbc:postgresql://your-rds-endpoint.region.rds.amazonaws.com:5432/lms
# SPRING_DATASOURCE_USERNAME=postgres
# SPRING_DATASOURCE_PASSWORD=change-me

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

FRONTEND_PORT=80
