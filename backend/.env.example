# Local development — copy to backend/.env and adjust as needed
# Spring Boot reads these via the custom .env loader + application.properties defaults

PORT=8082
SPRING_PROFILES_ACTIVE=postgres

# PostgreSQL (local install or: docker compose up postgres redis -f ../docker-compose.yml -f ../docker-compose.override.yml)
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/lms
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=postgres

# Redis (optional — app falls back to DB if Redis is unavailable)
REDIS_HOST=localhost
REDIS_PORT=6379

# Cloudinary (required for file uploads)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
